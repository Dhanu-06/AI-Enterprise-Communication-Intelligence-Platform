# Root Docker Compose variables
# Copy to .env:  copy .env.example .env

POSTGRES_USER=comm_intel
POSTGRES_PASSWORD=comm_intel_secret
POSTGRES_DB=comm_intel_db
POSTGRES_PORT=5432

ELASTICSEARCH_PORT=9200
ELASTICSEARCH_HEAP_SIZE=512m

CHROMA_PORT=8001

BACKEND_PORT=8000
FRONTEND_PORT=3000

# Browser-facing API URL (must be reachable from your machine, not Docker internal DNS)
# Browser uses same-origin /api/v1 (proxied by Next.js in Docker). For local npm dev without proxy, use http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=/api/v1
