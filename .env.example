# Docker Compose — copy to .env in project root
# Usage: cp .env.example .env && docker compose up -d --build

POSTGRES_USER=comm_intel
POSTGRES_PASSWORD=comm_intel_secret
POSTGRES_DB=comm_intel_db
POSTGRES_PORT=5432

ELASTICSEARCH_PORT=9200
ELASTICSEARCH_HEAP_SIZE=512m

CHROMA_PORT=8001

BACKEND_PORT=8000
FRONTEND_PORT=3000

# Browser uses Next.js rewrite; Docker frontend proxies to backend service
NEXT_PUBLIC_API_URL=/api/v1
