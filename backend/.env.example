# Application
DEBUG=true
APP_NAME=AI Enterprise Communication Intelligence Platform

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=comm_intel
POSTGRES_PASSWORD=comm_intel_secret
POSTGRES_DB=comm_intel_db

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=emails

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=email_embeddings
CHROMA_PERSIST_DIR=chroma_data

# AI / Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
SUMMARY_MODEL=google/flan-t5-base

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500
