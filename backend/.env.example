# Application
DEBUG=false
APP_NAME=AI Enterprise Communication Intelligence Platform

# Server (Railway injects PORT automatically)
HOST=0.0.0.0
PORT=8000

# CORS — add your Vercel production URL(s), comma-separated
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# PostgreSQL — local development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=comm_intel
POSTGRES_PASSWORD=comm_intel_secret
POSTGRES_DB=comm_intel_db

# PostgreSQL — Railway (auto-injected; overrides POSTGRES_* when set)
# DATABASE_URL=postgresql://postgres:password@hostname.railway.app:5432/railway

# Elasticsearch — local
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=emails
ELASTICSEARCH_INDEX_TEMPLATE=comm_intel_emails_template
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_TIMEOUT=30
ELASTICSEARCH_MAX_RETRIES=3

# Elasticsearch — Elastic Cloud
# ELASTICSEARCH_URL=https://your-deployment.es.us-east-1.aws.cloud.es.io:443
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=your-elastic-cloud-password

# ChromaDB — local Docker
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=email_embeddings
CHROMA_PERSIST_DIR=chroma_data
CHROMA_MODE=http
CHROMA_ENABLED=true

# ChromaDB — Railway private networking (use Railway internal hostname)
# CHROMA_HOST=chromadb.railway.internal
# CHROMA_PORT=8000

# AI / Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
SUMMARY_MODEL=google/flan-t5-base

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500
